# Copy this file to .env.local and fill in your Firebase web app credentials.
# Project Settings -> General -> Your apps -> SDK setup and configuration.
# If left blank, the site renders with built-in demo data.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Live Rust server / loading screen integration ---
# Shared secret: must match "API Key" in the Carbon plugin config.
PROJECT_RIFT_API_KEY=
# Direct query fallback (GameDig) if the plugin heartbeat is stale/absent.
RUST_SERVER_HOST=
RUST_SERVER_PORT=
# Display metadata shown on the site + /loading screen.
RUST_SERVER_NAME=PROJECT RIFT | RUST
RUST_SERVER_LOCATION=Singapore
RUST_SERVER_REGION=Asia
NEXT_PUBLIC_DISCORD_URL=https://discord.gg
NEXT_PUBLIC_SITE_URL=https://projectrift.esystemlk.com
# Optional explicit next wipe (ISO). If unset, API auto-computes next Thursday.
WIPE_NEXT=
